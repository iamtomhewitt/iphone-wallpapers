{
  "name": "iphone-wallpapers",
  "version": "0.1.0",
  "author": "Tom Hewitt",
  "scripts": {
    "build": "rm -rf dist && tsc -b && cp package.json dist/package.json && cd dist && npm i --omit=dev",
    "deploy": "sls deploy --aws-profile tom",
    "lint-fix": "iamtomhewitt-linter --sourceFolder=./ --type=typescript --fix",
    "prepare": "husky",
    "release": "iamtomhewitt-releaser && npm run build && npm run deploy",
    "start": "ts-node src/local.ts"
  },
  "dependencies": {
    "@iamtomhewitt/error": "3.1.0",
    "@iamtomhewitt/http": "3.1.0",
    "@vercel/og": "0.11.1",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@iamtomhewitt/linter": "3.1.0",
    "@iamtomhewitt/releaser": "3.1.0",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.2.3",
    "@types/react": "^19.2.14",
    "husky": "9.1.7",
    "serverless": "3.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
