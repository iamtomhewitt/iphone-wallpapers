{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "types": [
      "node"
    ],
  },
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "**/*.spec.ts"
  ]
}